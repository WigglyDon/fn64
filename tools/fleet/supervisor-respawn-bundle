#!/bin/sh
set -eu

packet_id=''
reply_to=''
context_sha=''
lane_id=''
lane_page=''
base=''
worktree=''
branch=''
candidate=''
latest_packet=''
artifact=''
goal=''
risk=''
next_action=''
authority=''
prohibited=''
proof=''
subsystems=''
validation=''
stale=''
allowed='NEEDS_FIX,PARTIAL,STOP'

usage() {
    printf '%s\n' 'usage: supervisor-respawn-bundle --packet-id ID --reply-to ID --context-sha SHA --lane-id ID --lane-page PATH --base SHA --worktree PATH --branch BRANCH --candidate-head SHA --latest-packet ID --artifact VALUE --goal VALUE --risk VALUE --next-action VALUE --authority VALUE --prohibited VALUE --proof VALUE --subsystems VALUE --validation VALUE --stale VALUE [--allowed CLASSES]'
}

while [ "$#" -gt 0 ]; do
    case "$1" in
        --packet-id) packet_id=$2; shift 2 ;; --reply-to) reply_to=$2; shift 2 ;;
        --context-sha) context_sha=$2; shift 2 ;; --lane-id) lane_id=$2; shift 2 ;;
        --lane-page) lane_page=$2; shift 2 ;; --base) base=$2; shift 2 ;;
        --worktree) worktree=$2; shift 2 ;; --branch) branch=$2; shift 2 ;;
        --candidate-head) candidate=$2; shift 2 ;; --latest-packet) latest_packet=$2; shift 2 ;;
        --artifact) artifact=$2; shift 2 ;; --goal) goal=$2; shift 2 ;;
        --risk) risk=$2; shift 2 ;; --next-action) next_action=$2; shift 2 ;;
        --authority) authority=$2; shift 2 ;; --prohibited) prohibited=$2; shift 2 ;;
        --proof) proof=$2; shift 2 ;; --subsystems) subsystems=$2; shift 2 ;;
        --validation) validation=$2; shift 2 ;; --stale) stale=$2; shift 2 ;;
        --allowed) allowed=$2; shift 2 ;; -h|--help) usage; exit 0 ;;
        *) usage >&2; exit 2 ;;
    esac
done

for pair in "packet-id:$packet_id" "reply-to:$reply_to" "context-sha:$context_sha" "lane-id:$lane_id" "lane-page:$lane_page" "base:$base" "worktree:$worktree" "branch:$branch" "candidate-head:$candidate" "latest-packet:$latest_packet" "artifact:$artifact" "goal:$goal" "risk:$risk" "next-action:$next_action" "authority:$authority" "prohibited:$prohibited" "proof:$proof" "subsystems:$subsystems" "validation:$validation" "stale:$stale"; do
    value=${pair#*:}
    [ -n "$value" ] || { printf 'supervisor-respawn-bundle: missing %s\n' "${pair%%:*}" >&2; exit 2; }
    printf '%s\n' "$value" | grep -Eq '<[^>]+>|\{\{[^}]+\}\}' && { printf 'supervisor-respawn-bundle: unresolved placeholder in %s\n' "${pair%%:*}" >&2; exit 1; }
done

cat <<EOF
BEGIN PROJECT PACKET
Packet-Version: 1.0
Packet-ID: $packet_id
Reply-To: $reply_to
From: Master GPT
To: Supervisor GPT
Project-ID: fn64
Lane-ID: $lane_id
Goal-ID: respawn-$lane_id
Context-SHA: $context_sha
Expected-Base: $base
Worktree: $worktree
Branch: $branch
Authority-State: $authority
Expected-Reply-Type: SUPERVISOR_SEED
Stale-When: $stale
Allowed-Stop-Classes: $allowed

Packet-Type: RESPAWN_SEED
Lane-Page: $lane_page
Latest-Candidate-HEAD: $candidate
Latest-Packet-ID: $latest_packet
Artifact-References: $artifact
Current-Goal: $goal
Unresolved-Risk: $risk
Exact-Next-Action: $next_action
Prohibited-Authority: $prohibited
Expected-Proof: $proof
Subsystem-Links: $subsystems
Required-Validation: $validation

Root-To-Local-Discovery: read root AGENTS.md; every scoped AGENTS.md to the lane; docs/INDEX.md; docs/context/CURRENT_STATE.md; rust/PARITY.md; relevant subsystem context; lane page; relevant contracts and evidence.
Private-Chat-Dependency: none
Worker branches pushed: no
Manual deploy performed: no

END PROJECT PACKET
EOF
