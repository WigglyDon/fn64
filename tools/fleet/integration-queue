#!/bin/sh
set -eu

script_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
root=$(CDPATH= cd -- "$script_dir/../.." && pwd)
queue=$root/ops/fleet/integration-queue.json
view=$root/docs/lanes/integration-queue.md

usage() {
    printf '%s\n' 'usage: integration-queue render|check [--queue PATH] [--view PATH]'
}

[ "$#" -ge 1 ] || { usage >&2; exit 2; }
command=$1
shift
while [ "$#" -gt 0 ]; do
    case "$1" in
        --queue) [ "$#" -ge 2 ] || { usage >&2; exit 2; }; queue=$2; shift 2 ;;
        --view) [ "$#" -ge 2 ] || { usage >&2; exit 2; }; view=$2; shift 2 ;;
        *) usage >&2; exit 2 ;;
    esac
done

validate_queue() {
    [ -f "$queue" ] || { printf 'integration-queue: missing queue: %s\n' "$queue" >&2; return 1; }
    grep -q '"schema": "fn64-integration-queue-v1"' "$queue" || {
        printf '%s\n' 'integration-queue: invalid schema' >&2
        return 1
    }
    entries=$(sed -n '/"entries"[[:space:]]*:/,/^[[:space:]]*]/p' "$queue")
    lane_ids=$(printf '%s\n' "$entries" | sed -n 's/.*"lane_id"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p')
    duplicates=$(printf '%s\n' "$lane_ids" | sed '/^$/d' | LC_ALL=C sort | uniq -d)
    [ -z "$duplicates" ] || {
        printf 'integration-queue: duplicate lane id: %s\n' "$duplicates" >&2
        return 1
    }
    printf '%s\n' "$entries" | awk '
        /"full_verify"/ && $0 !~ /"(NOT_RUN|PASS|FAIL|UNKNOWN)"/ { bad=1 }
        /"overlap_risk"/ && $0 !~ /"(NONE|LOW|DIRECT_OVERLAP|UNKNOWN)"/ { bad=1 }
        /"revalidation"/ && $0 !~ /"(NOT_REQUIRED|PENDING|PASS|FAIL|UNKNOWN)"/ { bad=1 }
        /"decision"/ && $0 !~ /"(PENDING|ACCEPT|REJECT|PARK|BLOCKED|UNKNOWN)"/ { bad=1 }
        /"push"/ && $0 !~ /"(NOT_AUTHORIZED|NOT_PUSHED|PUSHED|FAILED|UNKNOWN)"/ { bad=1 }
        END { exit bad }
    ' || {
        printf '%s\n' 'integration-queue: invalid state value' >&2
        return 1
    }
}

render_to_stdout() {
    cat <<'EOF'
# fn64 Integration Queue

Context role: generated human integration-queue view.
Scope: current worker-lane candidates awaiting Master integration.
Canonical for: nothing; generated from `ops/fleet/integration-queue.json`.
Not canonical for: source truth, acceptance, or lane implementation state.
Inherits: [lane registry](lane-registry.md).
Current-state owner: [CURRENT_STATE.md](../context/CURRENT_STATE.md).
Related evidence: [fleet operations](../context/subsystems/fleet-operations.md).
Update triggers: regenerate after the machine-readable queue changes.

<!-- generated by tools/fleet/integration-queue render; do not edit -->

Machine-readable owner: `ops/fleet/integration-queue.json`

| Lane ID | Candidate HEAD | Base | Context-SHA | Artifact | Targeted validation | Full verify | Overlap | Dependency | Authority impact | Revalidation | Decision | Push |
| --- | --- | --- | --- | --- | --- | --- | --- | --- | --- | --- | --- | --- |
EOF
    rows=$(sed -n '/"entries"[[:space:]]*:/,/^[[:space:]]*]/ {
        /"lane_id"/p
    }' "$queue")
    if [ -z "$rows" ]; then
        printf '\n%s\n' 'No active worker-lane candidates are queued.'
        return
    fi
    printf '%s\n' "$rows" | while IFS= read -r row; do
        values=$(printf '%s\n' "$row" | sed \
            -e 's/^[^{]*{//' -e 's/}[^}]*$//' \
            -e 's/"[^"]*"[[:space:]]*:[[:space:]]*"\([^"]*\)"[[:space:]]*,*/\1\t/g')
        printf '| %s |\n' "$(printf '%s' "$values" | sed 's/\t/ | /g; s/ | $//')"
    done
}

case "$command" in
    render)
        validate_queue
        render_to_stdout
        ;;
    check)
        validate_queue
        tmp=$(mktemp "${TMPDIR:-/tmp}/fn64-integration-queue.XXXXXX")
        trap 'rm -f "$tmp"' EXIT HUP INT TERM
        render_to_stdout >"$tmp"
        cmp -s "$tmp" "$view" || {
            printf '%s\n' 'integration-queue: generated view is stale' >&2
            diff -u "$view" "$tmp" >&2 || true
            exit 1
        }
        printf '%s\n' 'integration-queue: ok'
        ;;
    *) usage >&2; exit 2 ;;
esac
